# Shopify Admin API access token (used by push script)
# This is filled after running: npm run auth:token
SHOPIFY_ACCESS_TOKEN=

# OAuth app credentials from Shopify Dev Dashboard > Product Pusher > Settings
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Local callback used by the token helper script
SHOPIFY_REDIRECT_URI=http://127.0.0.1:3456/callback

# Embedded shell OAuth callback (Phase B)
EMBEDDED_SHOPIFY_REDIRECT_URI=http://127.0.0.1:4320/auth/callback

# OAuth scopes requested during token generation
SHOPIFY_SCOPES=read_products,write_products

# Optional explicit token-store encryption key.
# If omitted, token encryption falls back to SHOPIFY_CLIENT_SECRET.
SHOPIFY_AUTH_ENCRYPTION_KEY=

# Optional comma-separated previous keys for decrypting older rotated entries.
SHOPIFY_AUTH_ENCRYPTION_OLD_KEYS=

# Your Shopify store domain, no protocol.
# Example: your-store.myshopify.com
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Admin GraphQL API version
SHOPIFY_API_VERSION=2025-10

# Shopify API retry policy (C1-03)
SHOPIFY_API_MAX_RETRIES=5
SHOPIFY_API_RETRY_BASE_MS=500
SHOPIFY_API_RETRY_MAX_MS=8000
SHOPIFY_CREATE_RECOVERY_RETRIES=3

# Set true to log request payloads for debugging
DEBUG=false
